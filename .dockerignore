# .dockerignore for the commit-image build.
# Goal: bake in the FULL repo (including .git history — the grader uses it),
# dropping only local build artifacts and editor/OS cruft.

# ── Build outputs / local cruft ──────────────────────────────────────────────
build/
out/
mayhem-build/
mayhem-tests/
*.o
*.a
*.so
*.dylib
**/__pycache__/

# ── Editor / OS noise ────────────────────────────────────────────────────────
.DS_Store
*.swp
*~
